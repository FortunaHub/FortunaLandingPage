APP_URL="https://your-domain.com"

# GitHub Pages / static hosting:
# Use "/" for custom domains or org/user Pages roots.
# Use "/FortunaLandingPage/" only when the site is served from that repository subpath.
VITE_BASE_PATH="/"

# Optional. Leave empty unless the SPA is hosted under a fixed subpath and auto-detection is not enough.
VITE_ROUTER_BASENAME=""

# Formspree: form endpoint for Request Demo (optional, has default)
VITE_FORMSPREE_ENDPOINT="https://formspree.io/f/mwvnzkll"
